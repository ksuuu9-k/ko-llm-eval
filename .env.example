# ko-llm-eval environment example
#
# Copy this file to `.env` and fill in the real keys/URLs you want to use.
# You do not need to use every section below.
# Keep only the judges you actually want to enable.


# ============================================================================
# Semantic Judges
# ============================================================================

# Semantic Judge 1: OpenAI
KO_LLM_EVAL_SEMANTIC_JUDGE_1_PROVIDER=openai
KO_LLM_EVAL_SEMANTIC_JUDGE_1_MODEL=gpt-4.1-mini
KO_LLM_EVAL_SEMANTIC_JUDGE_1_API_KEY=replace_with_openai_key
KO_LLM_EVAL_SEMANTIC_JUDGE_1_NAME=openai_semantic
KO_LLM_EVAL_SEMANTIC_JUDGE_1_WEIGHT=0.225
KO_LLM_EVAL_SEMANTIC_JUDGE_1_BASE_URL=https://api.openai.com/v1
KO_LLM_EVAL_SEMANTIC_JUDGE_1_TIMEOUT_SECONDS=30
KO_LLM_EVAL_SEMANTIC_JUDGE_1_TEMPERATURE=0

# Semantic Judge 2: Claude
KO_LLM_EVAL_SEMANTIC_JUDGE_2_PROVIDER=anthropic
KO_LLM_EVAL_SEMANTIC_JUDGE_2_MODEL=claude-3-5-sonnet-latest
KO_LLM_EVAL_SEMANTIC_JUDGE_2_API_KEY=replace_with_anthropic_key
KO_LLM_EVAL_SEMANTIC_JUDGE_2_NAME=claude_semantic
KO_LLM_EVAL_SEMANTIC_JUDGE_2_WEIGHT=0.225
KO_LLM_EVAL_SEMANTIC_JUDGE_2_BASE_URL=https://api.anthropic.com
KO_LLM_EVAL_SEMANTIC_JUDGE_2_TIMEOUT_SECONDS=30
KO_LLM_EVAL_SEMANTIC_JUDGE_2_TEMPERATURE=0

# Optional Semantic Judge 3: Llama on OpenAI-compatible server
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_PROVIDER=openai_compatible
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_MODEL=meta-llama/Llama-3.1-70B-Instruct
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_API_KEY=replace_with_local_or_gateway_token
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_NAME=llama_semantic
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_BASE_URL=http://localhost:8000/v1
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_TIMEOUT_SECONDS=30
# KO_LLM_EVAL_SEMANTIC_JUDGE_3_TEMPERATURE=0


# ============================================================================
# Rubric Judges
# ============================================================================

# Rubric Judge 1: Gemini
KO_LLM_EVAL_RUBRIC_JUDGE_1_PROVIDER=gemini
KO_LLM_EVAL_RUBRIC_JUDGE_1_MODEL=gemini-2.5-pro
KO_LLM_EVAL_RUBRIC_JUDGE_1_API_KEY=replace_with_gemini_key
KO_LLM_EVAL_RUBRIC_JUDGE_1_NAME=gemini_rubric
KO_LLM_EVAL_RUBRIC_JUDGE_1_WEIGHT=0.175
KO_LLM_EVAL_RUBRIC_JUDGE_1_BASE_URL=https://generativelanguage.googleapis.com
KO_LLM_EVAL_RUBRIC_JUDGE_1_TIMEOUT_SECONDS=30
KO_LLM_EVAL_RUBRIC_JUDGE_1_TEMPERATURE=0

# Rubric Judge 2: Internal custom model
# KO_LLM_EVAL_RUBRIC_JUDGE_2_PROVIDER=custom
# KO_LLM_EVAL_RUBRIC_JUDGE_2_MODEL=internal-rubric-v1
# KO_LLM_EVAL_RUBRIC_JUDGE_2_API_KEY=replace_with_internal_token
# KO_LLM_EVAL_RUBRIC_JUDGE_2_NAME=internal_rubric
# KO_LLM_EVAL_RUBRIC_JUDGE_2_WEIGHT=0.175
# KO_LLM_EVAL_RUBRIC_JUDGE_2_BASE_URL=https://llm-gateway.internal
# KO_LLM_EVAL_RUBRIC_JUDGE_2_API_PATH=/judge
# KO_LLM_EVAL_RUBRIC_JUDGE_2_TIMEOUT_SECONDS=30
# KO_LLM_EVAL_RUBRIC_JUDGE_2_TEMPERATURE=0
# KO_LLM_EVAL_RUBRIC_JUDGE_2_EXTRA_HEADERS={"x-tenant":"eval-team"}
# KO_LLM_EVAL_RUBRIC_JUDGE_2_EXTRA_BODY={"team":"quality"}


# ============================================================================
# Legacy single-judge format
# ============================================================================
#
# The project still supports the old single semantic/rubric judge keys below
# for backward compatibility, but the numbered multi-judge format above is
# recommended for new setups.
#
# KO_LLM_EVAL_LLM_JUDGE_PROVIDER=openai
# KO_LLM_EVAL_LLM_JUDGE_MODEL=gpt-4.1-mini
# KO_LLM_EVAL_LLM_JUDGE_API_KEY=replace_with_openai_key
#
# KO_LLM_EVAL_KO_RUBRIC_JUDGE_PROVIDER=gemini
# KO_LLM_EVAL_KO_RUBRIC_JUDGE_MODEL=gemini-2.5-pro
# KO_LLM_EVAL_KO_RUBRIC_JUDGE_API_KEY=replace_with_gemini_key
